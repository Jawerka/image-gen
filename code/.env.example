# =============================================================================
# Image MCP Server - Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env
# =============================================================================

# ---------------------------------------------------------------------------
# Paths and Directories
# ---------------------------------------------------------------------------
# Base directory of the project
BASE_DIR=/root/image-gen/code

# Directory for generated images (can be outside the project)
IMAGE_DIR=/root/image-gen/images

# ---------------------------------------------------------------------------
# Stable Diffusion WebUI Connection
# ---------------------------------------------------------------------------
# URL of your SD WebUI server
SD_WEBUI_URL=http://127.0.0.1:7860

# Authentication (optional, leave empty if not needed)
SD_AUTH_USER=
SD_AUTH_PASS=

# Request timeout in seconds (600 = 10 minutes)
REQUEST_TIMEOUT=600

# MCP server timeout in seconds (900 = 15 minutes, must be > REQUEST_TIMEOUT)
MCP_TIMEOUT=900

# ---------------------------------------------------------------------------
# Default Generation Parameters
# ---------------------------------------------------------------------------
# Negative prompt (what should NOT be in the image)
SD_NEGATIVE_PROMPT=

# Steps (1-150, more = better quality but slower)
SD_STEPS=22

# Sampler name (Euler a, Euler, DPM++ 2M Karras, etc.)
SD_SAMPLER=Euler a

# Schedule type (Karras, Exponential, Polyexponential, etc.)
SD_SCHEDULE_TYPE=Karras

# CFG scale (1-30, higher = stricter prompt following)
SD_CFG_SCALE=5

# Seed (-1 for random, specific number for reproducibility)
SD_SEED=-1

# Default image dimensions (512-2048)
SD_WIDTH=1040
SD_HEIGHT=1160

# ---------------------------------------------------------------------------
# Upscaling Settings
# ---------------------------------------------------------------------------
# Resize mode (0-4)
SD_RESIZE_MODE=0

# Upscale multiplier (default 4x)
SD_UPSCALE_MULTIPLIER=4

# Target dimensions for upscale
SD_UPSCALE_WIDTH=512
SD_UPSCALE_HEIGHT=512

# Upscaler names (R-ESRGAN 4x+, ESRGAN_4x, etc.)
SD_UPSCALER_1=R-ESRGAN 4x+
SD_UPSCALER_2=None

# ---------------------------------------------------------------------------
# Web Server Settings
# ---------------------------------------------------------------------------
# Host to listen on (0.0.0.0 = all interfaces)
WEB_HOST=0.0.0.0

# Web server port (MCP will be on WEB_PORT + 1)
WEB_PORT=8080

# External URL for generating image links (must be accessible to MCP clients)
# For local access: http://localhost:8080
# For network access: http://YOUR_SERVER_IP:8080
PUBLIC_BASE_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# File Cleanup Settings
# ---------------------------------------------------------------------------
# How many days to keep images before auto-cleanup
IMAGE_RETENTION_DAYS=3